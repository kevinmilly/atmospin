{
  "name": "atmospin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "pipeline:query": "tsx scripts/query-wikidata.ts",
    "pipeline:enrich": "tsx scripts/enrich-with-haiku.ts",
    "pipeline:seed": "tsx scripts/seed-supabase.ts",
    "pipeline:migrate": "tsx scripts/run-migration.ts",
    "pipeline:test": "tsx scripts/query-wikidata.ts --limit 5 && tsx scripts/enrich-with-haiku.ts --limit 5 && tsx scripts/seed-supabase.ts --limit 5"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.15.0",
    "globe.gl": "^2.35.3",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-globe.gl": "^2.37.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.175.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.175.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  }
